# Supabase
SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# Redis
REDIS_URL=redis://localhost:6379

# API
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Auth
SITE_URL=http://localhost:5173

# Email (SMTP)
# For local dev, uses Supabase's Inbucket (view emails at http://localhost:54324)
SMTP_HOST=localhost
SMTP_PORT=54325
SMTP_FROM=noreply@broseph.local
# For production, add SMTP_USER and SMTP_PASS

# Stripe (for payment features)
# Get keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your-secret-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here
STRIPE_PUBLIC_KEY=pk_test_your-publishable-key-here

# Node environment
NODE_ENV=development
